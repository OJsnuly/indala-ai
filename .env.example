# ========================================
# inDala AI - Environment Variables
# ========================================
# Copy this file to .env before running:
#   cp .env.example .env
# ========================================

# ── Service Ports ──
GO_PORT=8080
PYTHON_PORT=8000
FRONTEND_PORT=3000
OSRM_PORT=5000

# ── External API Keys (add your own) ──
OPENWEATHER_API_KEY=your_key_here
OPENROUTESERVICE_API_KEY=your_key_here

# ── Internal Config ──
ML_SERVICE_URL=http://python-ml:8000
OSRM_URL=http://osrm-backend:5000
